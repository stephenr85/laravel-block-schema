{
    "name": "rushing/laravel-block-schema",
    "description": "A faithful ProseMirror document model for Laravel (Node/Document/Schema) plus a Spatie Data Block base class. Define your node types as Block subclasses; round-trip ProseMirror JSON.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "illuminate/contracts": "^12.0",
        "illuminate/support": "^12.0",
        "spatie/laravel-data": "^4.9",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "rushing/laravel-data-schemas": "^1.0"
    },
    "suggest": {
        "rushing/laravel-data-schemas": "Emit JSON Schema for Block subclasses (BlockJsonSchemaGenerator) for LLM structured output."
    },
    "repositories": {
        "laravel-data-schemas": {
            "type": "vcs",
            "url": "https://github.com/stephenr85/laravel-data-schemas.git"
        }
    },
    "autoload": {
        "psr-4": {
            "Rushing\\BlockSchema\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Rushing\\BlockSchema\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Rushing\\BlockSchema\\ServiceProvider"
            ]
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
