{
    "name": "rushing/laravel-block-schema",
    "description": "Spatie Data block types for ProseMirror document generation in Laravel. Plugs into rushing/prosemirror-php.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "illuminate/contracts": "^12.0",
        "rushing/prosemirror-php": "dev-main",
        "spatie/laravel-data": "^4.9",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Rushing\\BlockSchema\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Rushing\\BlockSchema\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Rushing\\BlockSchema\\ServiceProvider"
            ]
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "../prosemirror-php"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true
}
